<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestor Pacientes</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .font-mono { font-family: 'DM Mono', monospace; }
    </style>
</head>
<body class="bg-gray-50 min-h-screen">

    <nav class="bg-[#0a2e1a] px-8 h-14 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-emerald-600 rounded-lg flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 2a2 2 0 0 0-2 2v5H4a2 2 0 0 0-2 2v2c0 1.1.9 2 2 2h5v5c0 1.1.9 2 2 2h2a2 2 0 0 0 2-2v-5h5a2 2 0 0 0 2-2v-2a2 2 0 0 0-2-2h-5V4a2 2 0 0 0-2-2h-2z" /></svg>
            </div>
            <span class="text-white text-sm font-medium tracking-tight">UT San Vicente CES</span>
        </div>
        <div class="flex items-center gap-2 text-emerald-300 text-xs">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
            <span>Admin</span>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto px-6 py-8">
        @RenderBody()
    </main>

    <footer class="border-t border-gray-200 mt-auto py-4">
        <div class="max-w-6xl mx-auto px-6 text-center text-xs text-gray-400">
            UT San Vicente CES &copy; @DateTime.Now.Year
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>